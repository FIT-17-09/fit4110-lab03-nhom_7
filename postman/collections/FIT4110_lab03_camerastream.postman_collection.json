{
  "info": {
    "_postman_id": "fit4110-lab03-camerastream",
    "name": "FIT4110 Lab03 - CameraStream Contract Tests",
    "description": "Postman Collection for Lab 03: provider-side contract tests, consumer-side smoke tests, and Newman evidence.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const prefix = pm.environment.get('tracePrefix') || 'fit4110-lab03';",
          "pm.variables.set('traceId', prefix + '-' + Date.now());",
          "pm.request.headers.upsert({ key: 'X-Trace-Id', value: pm.variables.get('traceId') });"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "00_Health",
      "item": [
        {
          "name": "GET /health - service is alive",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response has service status', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('status');",
                  "  pm.expect(json).to.have.property('service');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "01_Functional",
      "item": [
        {
          "name": "POST /api/v1/vision/analyze - happy path accepted",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/vision/analyze",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "vision", "analyze"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"camera_id\": \"cam-gate-01-entry\",\n  \"image_url\": \"https://example.com/images/frame.jpg\",\n  \"timestamp\": \"2026-05-22T10:30:00Z\",\n  \"correlationId\": \"corr-001-2026\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 202', function () { pm.response.to.have.status(202); });",
                  "pm.test('Response confirms queued', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('status');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02_Auth",
      "item": [
        {
          "name": "POST /api/v1/vision/analyze - valid token accepted",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/vision/analyze",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "vision", "analyze"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"camera_id\": \"cam-gate-01-entry\",\n  \"image_url\": \"https://example.com/images/frame.jpg\",\n  \"timestamp\": \"2026-05-22T10:30:00Z\",\n  \"correlationId\": \"corr-010-2026\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Valid token request returns success', function () {",
                  "  pm.expect(pm.response.code).to.eql(202);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/v1/vision/analyze - missing token rejected on real service",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/vision/analyze",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "vision", "analyze"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"camera_id\": \"cam-gate-01-entry\",\n  \"image_url\": \"https://example.com/images/frame.jpg\",\n  \"timestamp\": \"2026-05-22T10:30:00Z\",\n  \"correlationId\": \"corr-011-2026\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const env = pm.environment.get('env') || 'mock';",
                  "if (env === 'mock') {",
                  "  pm.test('Skipped on mock: Prism does not enforce real auth', function () {",
                  "    pm.expect(true).to.eql(true);",
                  "  });",
                  "} else {",
                  "  pm.test('Missing token returns 401 or 403', function () {",
                  "    pm.expect([401, 403]).to.include(pm.response.code);",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/v1/vision/analyze - invalid token rejected on real service",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer invalid-token" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/vision/analyze",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "vision", "analyze"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"camera_id\": \"cam-gate-01-entry\",\n  \"image_url\": \"https://example.com/images/frame.jpg\",\n  \"timestamp\": \"2026-05-22T10:30:00Z\",\n  \"correlationId\": \"corr-012-2026\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const env = pm.environment.get('env') || 'mock';",
                  "if (env === 'mock') {",
                  "  pm.test('Skipped on mock: invalid token needs real auth', function () {",
                  "    pm.expect(true).to.eql(true);",
                  "  });",
                  "} else {",
                  "  pm.test('Invalid token returns 401 or 403', function () {",
                  "    pm.expect([401, 403]).to.include(pm.response.code);",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "03_Negative",
      "item": [
        {
          "name": "POST /api/v1/vision/analyze - missing image_url",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Prefer", "value": "code=400" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/vision/analyze",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "vision", "analyze"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"camera_id\": \"cam-gate-01-entry\",\n  \"timestamp\": \"2026-05-22T10:30:00Z\",\n  \"correlationId\": \"corr-020-2026\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Invalid payload returns client error', function () {",
                  "  pm.expect([400, 422]).to.include(pm.response.code);",
                  "});",
                  "pm.test('Error response follows ProblemDetails', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('title');",
                  "  pm.expect(json).to.have.property('status');",
                  "  pm.expect(json.status).to.be.within(400, 599);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/v1/vision/analyze - invalid image_url format",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Prefer", "value": "code=400" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/vision/analyze",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "vision", "analyze"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"camera_id\": \"cam-gate-01-entry\",\n  \"image_url\": \"not-a-url\",\n  \"timestamp\": \"2026-05-22T10:30:00Z\",\n  \"correlationId\": \"corr-021-2026\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Invalid image_url returns client error', function () {",
                  "  pm.expect([400, 422]).to.include(pm.response.code);",
                  "});",
                  "pm.test('Error response has detail', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('detail');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "04_Boundary_Reliability",
      "item": [
        {
          "name": "POST /api/v1/vision/analyze - boundary image size",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Prefer", "value": "code=400" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/vision/analyze",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "vision", "analyze"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"camera_id\": \"cam-gate-01-entry\",\n  \"image_url\": \"https://example.com/images/frame-5mb.jpg\",\n  \"timestamp\": \"2026-05-22T10:30:00Z\",\n  \"correlationId\": \"corr-030-2026\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Boundary image size is accepted or rejected', function () {",
                  "  pm.expect([202, 400, 422]).to.include(pm.response.code);",
                  "});",
                  "if ([400, 422].includes(pm.response.code)) {",
                  "  pm.test('Boundary error follows ProblemDetails', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('status');",
                  "    pm.expect(json.status).to.be.within(400, 599);",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "05_Consumer_side_Smoke",
      "item": [
        {
          "name": "Consumer smoke - CameraStream calls AI Vision mock",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{aiVisionMockUrl}}/api/v1/vision/analyze",
              "host": ["{{aiVisionMockUrl}}"],
              "path": ["api", "v1", "vision", "analyze"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"camera_id\": \"CAM01\",\n  \"image_url\": \"https://example.com/frame.jpg\",\n  \"timestamp\": \"2026-05-22T10:30:00Z\",\n  \"correlationId\": \"corr-smoke-001\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Consumer receives accepted response from provider mock', function () {",
                  "  pm.expect(pm.response.code).to.eql(202);",
                  "});",
                  "pm.test('Consumer can read queued status', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('status');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
